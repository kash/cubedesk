{
	"presets": [
		"@babel/typescript",
		"@babel/react",
		[
			"@babel/preset-env",
			{
				"targets": {
					"node": "current"
				}
			}
		]
	],
	"plugins": [
		"babel-plugin-transform-typescript-metadata",
		[
			"@babel/plugin-proposal-decorators",
			{
				"legacy": true
			}
		],
		[
			"babel-plugin-transform-remove-imports",
			{
				"test": "\\.(scss|css)$"
			}
		]
	]
}