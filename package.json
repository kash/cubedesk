		"@prisma/client": "^7.0.1",
		"@react-email/components": "^1.0.12",
		"@sentry/browser": "^6.3.5",
		"@sentry/node": "^6.16.1",
		"@sentry/tracing": "^6.16.1",
		"@socket.io/redis-adapter": "^8.3.0",
		"@tanstack/react-query": "^5.101.2",
		"@trpc/client": "^11.18.0",
