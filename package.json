{
	"name": "cubedesk",
	"version": "1.0.0",
	"description": "CubeDesk's codebase",
	"author": "Kash Goudarzi",
	"license": "CubeDesk, Inc. All Rights Reserved",
	"main": "server/app.ts",
	"packageManager": "pnpm@10.9.0",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "vite build",
		"server": "ts-node-dev -r tsconfig-paths/register --transpile-only --quiet --exit-child --ignore-watch client ./server/app.ts",
		"dev": "pnpm run server",
		"devs": "HTTPS=true pnpm run server",
		"dev2": "PORT=3001 pnpm run server",
		"prisma": "prisma format && rm -rf generated/zod && prisma generate && prisma migrate dev",
		"test": "jest",
		"lint": "pnpm run lint:eslint",
		"lint:eslint": "eslint --fix --ignore-pattern='debug/*,__scripts__/*,src/app/*,generated/*,*.mjs,lambda/*' .",
		"compile-server": "babel server --out-dir ./build/server --extensions \".ts,.js,.jsx,.tsx\" -s --config-file ./prod.babelrc",
		"compile-client": "babel client --out-dir ./build/client --extensions \".ts,.js,.jsx,.tsx\" -s --config-file ./prod.babelrc",
		"compile-shared": "babel shared --out-dir ./build/shared --extensions \".ts,.js,.jsx,.tsx\" -s --config-file ./prod.babelrc",
		"compile-generated": "babel generated --out-dir ./build/generated --extensions \".ts,.js\" -s --config-file ./prod.babelrc",
		"compile-types": "babel types --out-dir ./build/types --extensions \".ts,.js\" -s --config-file ./prod.babelrc",
		"deploy": "pnpm run build && pnpm run compile-server && pnpm run compile-client && pnpm run compile-shared && pnpm run compile-generated && pnpm run compile-types"
	},
	"engines": {
		"node": "24.x"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@/generated/(.*)$": "<rootDir>/generated/$1",
			"^@/types/(.*)$": "<rootDir>/types/$1",
			"^@/server/(.*)$": "<rootDir>/server/$1",
			"^@/client/shared/(.*)$": "<rootDir>/client/shared/$1",
			"^@/shared/(.*)$": "<rootDir>/shared/$1",
			"^@/(.*)$": "<rootDir>/client/$1",
			"\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
			"\\.(css|less)$": "identity-obj-proxy"
		},
		"transform": {
			"node_modules/variables/.+\\.(j|t)sx?$": "ts-jest"
		},
		"transformIgnorePatterns": [
			"node_modules/(?!variables/.*)"
		],
		"setupFiles": [
			"./server/__test__/jest.setup.ts"
		]
	},
	"dependencies": {
		"@aws-sdk/client-cloudfront": "^3.1079.0",
		"@aws-sdk/client-s3": "^3.1079.0",
		"@aws-sdk/client-ses": "^3.1079.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
